flowchart TB
    subgraph User["👤 Usuário"]
        direction LR
        U1[Terminal]
        U2["💻 HTTP Client<br/>(curl, browser, scripts)"]
        U3[Telegram App]
    end

    subgraph Interfaces["🎨 Interfaces / Adapters"]
        CLI["main.py<br/>Legacy CLI Loop"]
        TUI["jurbas_code/tui/app.py<br/>JurbasTUI (Textual)"]
        TG["jurbas_code/telegram_adapter.py<br/>TelegramAdapter"]
        API["🆕 jurbas_code/api/<br/>REST API Server<br/>(FastAPI/Starlette)"]
    end

    subgraph IFACE_PROTOCOL["🔌 Interface Protocol"]
        PROTO["AgentCallback<br/>Protocol / ABC"]
    end

    subgraph Core["🧠 Core Agent"]
        AGENT["jurbas_code/agent.py<br/>Agent class"]
        AGENT_CHAT["Agent.chat()"]
    end

    subgraph Services["⚙️ Serviços"]
        PROV["jurbas_code/providers.py<br/>LLM Provider Factory"]
        TOOLS["jurbas_code/tools.py<br/>Tool Handlers"]
        SCHEMAS["jurbas_code/tool_schemas.py<br/>Tool JSON Schemas"]
        SEC["jurbas_code/security.py<br/>Path Validation + Confirmation"]
        PROMPTS["jurbas_code/prompts.py<br/>System Prompt"]
        CMDS["jurbas_code/commands.py<br/>Slash Commands"]
        SESSION_MGR["🆕 Session Manager<br/>(state container per session)"]
    end

    subgraph External["🌐 External Services"]
        LLM_DP["DeepSeek API"]
        LLM_CL["Claude Code OAuth"]
        WEB["Web Search (DDGS)"]
        FS["📁 Filesystem"]
    end

    U1 --> CLI
    U1 --> TUI
    U2 --> API
    U3 --> TG

    CLI -.->|implements| PROTO
    TUI -.->|implements| PROTO
    TG -.->|implements| PROTO
    API -.->|implements| PROTO

    PROTO --> AGENT_CHAT

    AGENT --> AGENT_CHAT
    AGENT_CHAT --> PROV
    AGENT_CHAT --> TOOLS
    AGENT_CHAT --> CMDS
    AGENT_CHAT --> SESSION_MGR

    PROV --> LLM_DP
    PROV --> LLM_CL
    TOOLS --> WEB
    TOOLS --> FS
    TOOLS --> SEC

    classDef current fill:#1a73e8,color:#fff,stroke:#0d47a1,stroke-width:2px
    classDef external fill:#2e7d32,color:#fff,stroke:#1b5e20,stroke-width:1px
